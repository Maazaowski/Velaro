{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Velaro",
  "version": "0.1.0",
  "identifier": "com.velaro.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Velaro",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "shortDescription": "Build and run your own LLM models — no code required.",
    "longDescription": "Velaro is a no-code desktop tool for building, training, testing, and deploying local LLM models.",
    "copyright": "Copyright © 2025 Velaro",
    "category": "DeveloperTool"
  }
}
